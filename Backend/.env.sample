# .env.sample - safe to commit
# Copy to .env and fill real values. Do NOT commit .env.

DB_USER=your_db_user
DB_PASS=your_db_password
DB_URL=jdbc:mysql://localhost:3306/YourDatabaseName

# JWT settings
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRATION=time_in_milisecond

# Mail settings (use app password / secret, not your account password if using Gmail)
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_app_password